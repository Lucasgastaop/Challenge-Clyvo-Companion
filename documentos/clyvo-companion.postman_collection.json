{
  "info": {
    "name": "Clyvo Companion API",
    "description": "Coleção FIAP Java Advanced — 18 requisições numeradas. No Collection Runner, rode a coleção inteira (ou a pasta única) com a API no Oracle.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "idUsuario", "value": "1" },
    { "key": "idPet", "value": "1" },
    { "key": "idClinica", "value": "1" },
    { "key": "idAgendamento", "value": "1" },
    { "key": "cnpjTeste", "value": "12345678000199" }
  ],
  "item": [
    {
      "name": "00 - Fluxo Entrega (executar em ordem)",
      "description": "Rode esta pasta com Collection Runner. E-mails e CNPJ usam timestamp para evitar conflito no Oracle. IDs são atualizados automaticamente após cada POST.",
      "item": [
        {
          "name": "01 - Listar usuarios",
          "request": { "method": "GET", "url": "{{baseUrl}}/usuarios?page=0&size=5" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "02 - Criar usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeUsuario\": \"Tutor Teste FIAP\",\n  \"email\": \"tutor.{{$timestamp}}@fiap.com.br\",\n  \"senha\": \"senha123\",\n  \"tpPerfil\": \"TUTOR\"\n}"
            },
            "url": "{{baseUrl}}/usuarios"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('idUsuario', pm.response.json().idUsuario);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "03 - Buscar usuario por ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/usuarios/{{idUsuario}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "04 - Criar clinica",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var ts = Date.now().toString();",
                  "var cnpj = ('00000000000000' + ts).slice(-14);",
                  "pm.collectionVariables.set('cnpjTeste', cnpj);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('idClinica', pm.response.json().idClinica);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeClinica\": \"Clinica Teste FIAP\",\n  \"cnpj\": \"{{cnpjTeste}}\",\n  \"endereco\": \"Av. Paulista, 1000\",\n  \"telefone\": \"11999990000\"\n}"
            },
            "url": "{{baseUrl}}/clinicas"
          }
        },
        {
          "name": "05 - Criar pet",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idUsuario\": {{idUsuario}},\n  \"nomePet\": \"Thor Teste\",\n  \"especie\": \"Cachorro\",\n  \"dtNascimento\": \"2020-05-10\"\n}"
            },
            "url": "{{baseUrl}}/pets"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('idPet', pm.response.json().idPet);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "06 - Listar pets",
          "request": { "method": "GET", "url": "{{baseUrl}}/pets?page=0&size=5" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "07 - Buscar pet por ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/pets/{{idPet}}" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "08 - Resumo saude do pet",
          "request": { "method": "GET", "url": "{{baseUrl}}/pets/{{idPet}}/resumo-saude" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "09 - Criar prescricao",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idPet\": {{idPet}},\n  \"nomeMedicamento\": \"Antibiotico\",\n  \"dsDosagem\": \"10mg\",\n  \"frequenciaHoras\": 12,\n  \"dtInicio\": \"2026-05-01\",\n  \"dtFim\": \"2026-12-31\"\n}"
            },
            "url": "{{baseUrl}}/prescricoes"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 201', () => pm.response.to.have.status(201));"] } }]
        },
        {
          "name": "10 - Listar prescricoes ativas",
          "request": { "method": "GET", "url": "{{baseUrl}}/prescricoes/ativas?idPet={{idPet}}&page=0&size=10" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "11 - Criar log saude (temperatura alta)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idPet\": {{idPet}},\n  \"dtRegistro\": \"2026-05-21T14:00:00\",\n  \"vlMetrica\": 39.8,\n  \"metrica\": \"temperatura\",\n  \"obs\": \"Teste alerta - febre\"\n}"
            },
            "url": "{{baseUrl}}/logs-saude"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 201', () => pm.response.to.have.status(201));"] } }]
        },
        {
          "name": "12 - Listar alertas de saude",
          "request": { "method": "GET", "url": "{{baseUrl}}/logs-saude/alertas?idPet={{idPet}}&page=0&size=10" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "13 - Criar agendamento",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idPet\": {{idPet}},\n  \"idClinica\": {{idClinica}},\n  \"dtAgenda\": \"2026-08-15T10:00:00\",\n  \"tipoServico\": \"Consulta\",\n  \"status\": \"AGENDADO\"\n}"
            },
            "url": "{{baseUrl}}/agendamentos"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('idAgendamento', pm.response.json().idAgendamento);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "14 - Concluir agendamento (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CONCLUIDO\"\n}" },
            "url": "{{baseUrl}}/agendamentos/{{idAgendamento}}/status"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "15 - Transicao invalida (esperado 400)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CANCELADO\"\n}" },
            "url": "{{baseUrl}}/agendamentos/{{idAgendamento}}/status"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 400', () => pm.response.to.have.status(400));"] } }]
        },
        {
          "name": "16 - Validacao Bean Validation (esperado 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idUsuario\": {{idUsuario}},\n  \"nomePet\": \"\",\n  \"especie\": \"Gato\"\n}" },
            "url": "{{baseUrl}}/pets"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 400', () => pm.response.to.have.status(400));"] } }]
        },
        {
          "name": "17 - Pet inexistente (esperado 404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Usuario", "value": "maria@fiap.com.br" }],
            "url": "{{baseUrl}}/pets/999999"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 404', () => pm.response.to.have.status(404));"] } }]
        },
        {
          "name": "18 - Ver log automatico no sistema",
          "request": { "method": "GET", "url": "{{baseUrl}}/logs-sistema?cdErro=404&page=0&size=5&sort=dtErro,desc" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] } }]
        }
      ]
    }
  ]
}
